#!/usr/bin/env python3
"""Install the public astro-commerce CLI into a bin directory."""

from __future__ import annotations

import argparse
import os
import sys
from pathlib import Path

SCRIPT_DIR = Path(__file__).resolve().parent
PACKAGE_DIR = SCRIPT_DIR.parent
DEFAULT_BIN = Path.home() / "clawd-work" / "bin"
PUBLIC_COMMAND = "astro-commerce"


def link_or_copy(src: Path, dst: Path, copy: bool = False):
    if dst.exists() or dst.is_symlink():
        dst.unlink()
    if copy:
        dst.write_bytes(src.read_bytes())
        dst.chmod(0o755)
    else:
        dst.symlink_to(src)


def main() -> int:
    parser = argparse.ArgumentParser(description="Install the astro-commerce CLI")
    parser.add_argument("--bin-dir", default=str(DEFAULT_BIN), help="Directory to install the command into")
    parser.add_argument("--copy", action="store_true", help="Copy the script instead of symlinking")
    parser.add_argument("--with-deps", action="store_true", help="Install Python dependencies with pip --user")
    args = parser.parse_args()

    bin_dir = Path(os.path.expanduser(args.bin_dir))
    bin_dir.mkdir(parents=True, exist_ok=True)

    src = SCRIPT_DIR / PUBLIC_COMMAND
    if not src.exists():
        print(f"Error: missing {src}", file=sys.stderr)
        return 1

    src.chmod(0o755)
    link_or_copy(src, bin_dir / PUBLIC_COMMAND, copy=args.copy)
    print(f"Installed {bin_dir / PUBLIC_COMMAND} -> {src}")

    if args.with_deps:
        import subprocess
        req = PACKAGE_DIR / "requirements.txt"
        if not req.exists():
            print(f"No requirements.txt found at {req}", file=sys.stderr)
            return 1
        subprocess.check_call([sys.executable, "-m", "pip", "install", "--user", "-r", str(req)])

    print("\nMake sure this directory is on PATH:")
    print(f"  {bin_dir}")
    print("\nTry:")
    print("  astro-commerce doctor")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
